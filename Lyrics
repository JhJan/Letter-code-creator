                <div class="mt-3 p-3 bg-black border border-gray-800 rounded flex items-center justify-between">
                    <code id="guide-url" class="text-[13px] text-gray-300 select-all font-mono">https://raw.githack.com/JhJan/Songs-Lyrics/main/cancion.html</code>
                    <button id="btn-copy-url" class="text-gray-500 hover:text-white" title="Copiar URL">
                        <i data-lucide="copy" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>

        </div>
    </main>

